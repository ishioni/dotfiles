// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "model": "claude-sonnet-4-6",
      "provider": "zed.dev",
    },
    "default_profile": "ask",
    "dock": "left",
    "favorite_models": [],
    "model_parameters": [],
    "profiles": {},
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    {{- if .workMachine }}
    "codex-acp": {
      "type": "registry",
    },
    {{- end }}
    "opencode": {
      "type": "registry",
    },
  },
  "allow_rewrap": "in_comments",
  "auto_indent_on_paste": true,
  "base_keymap": "Atom",
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "buffer_font_size": 14.0,
  "buffer_line_height": "standard",
  "calls": {
    "mute_on_join": true,
  },
  "cli_default_open_behavior": "new_window",
  "collaboration_panel": {
    "dock": "right",
  },
  "colorize_brackets": true,
  "context_servers": {
    {{- if .workMachine }}
    "toolhive-docplanner": {
      "enabled": false,
      "url": "https://toolhive-codex.docplanner.io/mcp",
    },
    {{- end }}
    "toolhive-movishell": {
      "enabled": false,
      "url": "https://mcp.movishell.pl/mcp",
    },
    "toolhive-movishell-local": {
      "enabled": true,
      "url": "https://mcp.ishioni.casa/mcp",
    },
  },
  "current_line_highlight": "all",
  "cursor_shape": "bar",
  "diagnostics": {
    "button": true,
    "inline": {
      "enabled": false,
    },
  },
  "disable_ai": false,
  "edit_predictions": {
    "mode": "subtle",
  },
  "file_types": {
    "Helm": [
      "**/templates/**/*.tpl",
      "**/templates/**/*.yaml",
      "**/templates/**/*.yml",
    ],
    "OpenTofu": ["tf", "tofu"],
    "OpenTofu Vars": ["tfvars"],
  },
  "git": {
    "branch_picker": {
      "show_author_name": false,
    },
    "hunk_style": "staged_hollow",
    "inline_blame": {
      "show_commit_summary": false,
    },
    "path_style": "file_name_first",
  },
  "git_panel": {
    "diff_stats": true,
    "dock": "left",
    "fallback_branch_name": "master",
    "file_icons": false,
    "show_count_badge": false,
    "sort_by_path": false,
    "tree_view": true,
  },
  "icon_theme": "Catppuccin Macchiato",
  "indent_guides": {
    "background_coloring": "indent_aware",
    "coloring": "fixed",
  },
  "minimap": {
    "show": "never",
  },
  "multi_cursor_modifier": "cmd_or_ctrl",
  "outline_panel": {
    "dock": "right",
  },
  "preferred_line_length": 100,
  "prettier": {
    "allowed": true,
    "bracketSpacing": false,
    "singleQuote": false,
    "tabWidth": 2,
  },
  "project_panel": {
    "bold_folder_labels": false,
    "button": true,
    "diagnostic_badges": false,
    "dock": "left",
    "entry_spacing": "comfortable",
    "git_status_indicator": false,
    "hide_hidden": false,
    "hide_root": true,
  },
  "relative_line_numbers": "disabled",
  "rounded_selection": true,
  "semantic_tokens": "combined",
  "soft_wrap": "preferred_line_length",
  "status_bar": {
    "active_language_button": true,
    "cursor_position_button": true,
    "show_active_file": false,
  },
  "tab_bar": {
    "show": true,
  },
  "tab_size": 2,
  "tabs": {
    "git_status": false,
  },
  "terminal": {
    "flexible": true,
    "toolbar": {
      "breadcrumbs": false,
    },
  },
  "theme": "Nord Dark",
  "title_bar": {
    "show_branch_status_icon": false,
    "show_menus": false,
  },
  "toolbar": {
    "agent_review": true,
    "breadcrumbs": true,
    "code_actions": false,
    "quick_actions": true,
    "selections_menu": true,
  },
  "ui_font_size": 16,
}
